{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 10,
      "includeFiles": "app/**",
      "excludeFiles": "{tests/**,db/**,scripts/**,csv/**,.venv/**,**/__pycache__/**}"
    }
  }
}
